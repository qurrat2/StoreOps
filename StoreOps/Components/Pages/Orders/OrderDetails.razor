@page "/orders/{Id:int}"
@rendermode InteractiveServer
@using StoreOps.Models.Enums
@inject IOrderService OrderService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Order Details</PageTitle>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (order is null)
{
    <div class="alert alert-warning">Order not found.</div>
    <a href="/orders" class="btn btn-secondary">Back to list</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Order <code>@order.OrderNumber</code></h1>
        <a href="/orders" class="btn btn-outline-secondary">Back to list</a>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Customer</h5>
                    <p class="mb-1">@order.CustomerName</p>
                    <p class="mb-0 text-muted small">Placed @order.OrderDate.ToString("yyyy-MM-dd HH:mm")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Status</h5>
                    <div class="mb-2">@StatusBadge(order.Status) @PaymentBadge(order.PaymentStatus)</div>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var next in NextStatusOptions(order.Status))
                        {
                            var target = next;
                            <button class="btn btn-sm @ButtonClass(target)" @onclick="() => ChangeStatus(target)" disabled="@acting">
                                @ButtonLabel(target)
                            </button>
                        }
                        @if (order.PaymentStatus != PaymentStatus.Paid && order.Status != OrderStatus.Cancelled)
                        {
                            <button class="btn btn-sm btn-success" @onclick="MarkPaid" disabled="@acting">Mark as Paid</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h5>Items</h5>
    <table class="table">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Product</th>
                <th class="text-end">Qty</th>
                <th class="text-end">Unit Price</th>
                <th class="text-end">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in order.Items)
            {
                <tr>
                    <td><code>@item.ProductSku</code></td>
                    <td>@item.ProductName</td>
                    <td class="text-end">@item.Quantity</td>
                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                    <td class="text-end">@item.LineTotal.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="row justify-content-end">
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between"><span>Subtotal</span><strong>@order.Subtotal.ToString("C")</strong></div>
                    <div class="d-flex justify-content-between text-muted small"><span>+ Shipping</span><span>@order.ShippingAmount.ToString("C")</span></div>
                    <div class="d-flex justify-content-between text-muted small"><span>- Discount</span><span>@order.DiscountAmount.ToString("C")</span></div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fs-5"><span>Total</span><strong>@order.TotalAmount.ToString("C")</strong></div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(order.Notes))
    {
        <div class="mt-3">
            <h6>Notes</h6>
            <p class="text-muted">@order.Notes</p>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private OrderDto? order;
    private bool loading = true;
    private bool acting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        order = await OrderService.GetByIdAsync(Id);
        loading = false;
    }

    private async Task ChangeStatus(OrderStatus newStatus)
    {
        if (newStatus == OrderStatus.Cancelled)
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "Cancel this order? Stock will be restored.");
            if (!ok) return;
        }

        acting = true;
        errorMessage = null;
        var result = await OrderService.UpdateStatusAsync(new UpdateOrderStatusDto { Id = Id, NewStatus = newStatus });
        acting = false;

        if (result.IsFailure) { errorMessage = result.Error; return; }
        await LoadAsync();
    }

    private async Task MarkPaid()
    {
        acting = true;
        errorMessage = null;
        var result = await OrderService.MarkPaidAsync(Id);
        acting = false;

        if (result.IsFailure) { errorMessage = result.Error; return; }
        await LoadAsync();
    }

    private static IEnumerable<OrderStatus> NextStatusOptions(OrderStatus current) => current switch
    {
        OrderStatus.Pending    => new[] { OrderStatus.Processing, OrderStatus.Cancelled },
        OrderStatus.Processing => new[] { OrderStatus.Shipped, OrderStatus.Cancelled },
        OrderStatus.Shipped    => new[] { OrderStatus.Delivered, OrderStatus.Cancelled },
        _                      => Array.Empty<OrderStatus>()
    };

    private static string ButtonClass(OrderStatus s) => s == OrderStatus.Cancelled ? "btn-outline-danger" : "btn-primary";

    private static string ButtonLabel(OrderStatus s) => s switch
    {
        OrderStatus.Processing => "Move to Processing",
        OrderStatus.Shipped    => "Mark Shipped",
        OrderStatus.Delivered  => "Mark Delivered",
        OrderStatus.Cancelled  => "Cancel Order",
        _                      => s.ToString()
    };

    private static RenderFragment StatusBadge(OrderStatus s) => builder =>
    {
        var (cls, text) = s switch
        {
            OrderStatus.Pending    => ("bg-warning text-dark", "Pending"),
            OrderStatus.Processing => ("bg-info text-dark", "Processing"),
            OrderStatus.Shipped    => ("bg-primary", "Shipped"),
            OrderStatus.Delivered  => ("bg-success", "Delivered"),
            OrderStatus.Cancelled  => ("bg-secondary", "Cancelled"),
            _                      => ("bg-light text-dark", s.ToString())
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {cls} me-1");
        builder.AddContent(2, text);
        builder.CloseElement();
    };

    private static RenderFragment PaymentBadge(PaymentStatus s) => builder =>
    {
        var (cls, text) = s switch
        {
            PaymentStatus.Pending  => ("bg-warning text-dark", "Payment: Pending"),
            PaymentStatus.Paid     => ("bg-success", "Payment: Paid"),
            PaymentStatus.Failed   => ("bg-danger", "Payment: Failed"),
            PaymentStatus.Refunded => ("bg-secondary", "Payment: Refunded"),
            _                      => ("bg-light text-dark", s.ToString())
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {cls}");
        builder.AddContent(2, text);
        builder.CloseElement();
    };
}
