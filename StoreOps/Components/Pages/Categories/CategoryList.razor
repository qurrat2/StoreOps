@page "/categories"
@rendermode InteractiveServer
@inject ICategoryService CategoryService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Categories</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Categories</h1>
    <button class="btn btn-primary" @onclick="GoToCreate">
        <i class="bi bi-plus-lg"></i> New Category
    </button>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (categories.Count == 0)
{
    <div class="alert alert-secondary">
        No categories yet. Click <strong>New Category</strong> to add one.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Status</th>
                <th>Created</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in categories)
            {
                <tr>
                    <td>@cat.Name</td>
                    <td>@(cat.Description ?? "—")</td>
                    <td>
                        @if (cat.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>@cat.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => GoToEdit(cat.Id)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(cat.Id, cat.Name)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@code {
    private IReadOnlyList<CategoryDto> categories = [];
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
    }

    private async Task LoadCategoriesAsync()
    {
        loading = true;
        categories = await CategoryService.GetAllAsync(includeInactive: true);
        loading = false;
    }

    private void GoToCreate() => Nav.NavigateTo("/categories/create");

    private void GoToEdit(int id) => Nav.NavigateTo($"/categories/{id}/edit");

    private async Task DeleteAsync(int id, string name)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Deactivate category '{name}'?");
        if (!confirmed) return;

        var result = await CategoryService.DeleteAsync(id);
        if (result.IsFailure)
        {
            errorMessage = result.Error;
            return;
        }

        errorMessage = null;
        await LoadCategoriesAsync();
    }
}
