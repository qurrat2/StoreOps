@page "/customers"
@rendermode InteractiveServer
@inject ICustomerService CustomerService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Customers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Customers</h1>
    <button class="btn btn-primary" @onclick="GoToCreate">
        <i class="bi bi-plus-lg"></i> New Customer
    </button>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (customers.Count == 0)
{
    <div class="alert alert-secondary">
        No customers yet. Click <strong>New Customer</strong> to add one.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>City</th>
                <th>Status</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in PagedCustomers)
            {
                <tr>
                    <td>@c.FullName</td>
                    <td>@c.Email</td>
                    <td>@(c.Phone ?? "—")</td>
                    <td>@(c.City ?? "—")</td>
                    <td>
                        @if (c.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => GoToEdit(c.Id)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(c.Id, c.FullName)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <Pagination TotalItems="customers.Count" PageSize="PageSize" CurrentPage="currentPage" OnPageChange="ChangePage" />
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@code {
    private const int PageSize = 15;
    private IReadOnlyList<CustomerDto> customers = [];
    private int currentPage = 1;
    private bool loading = true;
    private string? errorMessage;

    private IEnumerable<CustomerDto> PagedCustomers =>
        customers.Skip((currentPage - 1) * PageSize).Take(PageSize);

    private void ChangePage(int page) => currentPage = page;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        loading = true;
        customers = await CustomerService.GetAllAsync(includeInactive: true);
        var totalPages = Math.Max(1, (int)Math.Ceiling((double)customers.Count / PageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        loading = false;
    }

    private void GoToCreate() => Nav.NavigateTo("/customers/create");

    private void GoToEdit(int id) => Nav.NavigateTo($"/customers/{id}/edit");

    private async Task DeleteAsync(int id, string name)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Deactivate customer '{name}'?");
        if (!confirmed) return;

        var result = await CustomerService.DeleteAsync(id);
        if (result.IsFailure)
        {
            errorMessage = result.Error;
            return;
        }

        errorMessage = null;
        await LoadCustomersAsync();
    }
}
