@if (TotalItems > 0)
{
    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
        <div class="text-muted small">
            Showing <strong>@FirstItem</strong>–<strong>@LastItem</strong> of <strong>@TotalItems</strong>
        </div>
        @if (TotalPages > 1)
        {
            <nav aria-label="pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => Go(CurrentPage - 1)" disabled="@(CurrentPage == 1)" aria-label="Previous">
                            &lsaquo;
                        </button>
                    </li>
                    @foreach (var page in VisiblePages())
                    {
                        if (page == -1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        else
                        {
                            var p = page;
                            <li class="page-item @(p == CurrentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => Go(p)">@p</button>
                            </li>
                        }
                    }
                    <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => Go(CurrentPage + 1)" disabled="@(CurrentPage == TotalPages)" aria-label="Next">
                            &rsaquo;
                        </button>
                    </li>
                </ul>
            </nav>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public int TotalItems { get; set; }
    [Parameter] public int PageSize { get; set; } = 15;
    [Parameter, EditorRequired] public int CurrentPage { get; set; } = 1;
    [Parameter] public EventCallback<int> OnPageChange { get; set; }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)TotalItems / PageSize));
    private int FirstItem => TotalItems == 0 ? 0 : (CurrentPage - 1) * PageSize + 1;
    private int LastItem => Math.Min(CurrentPage * PageSize, TotalItems);

    private async Task Go(int page)
    {
        if (page < 1 || page > TotalPages || page == CurrentPage) return;
        await OnPageChange.InvokeAsync(page);
    }

    private IEnumerable<int> VisiblePages()
    {
        if (TotalPages <= 7)
        {
            for (int i = 1; i <= TotalPages; i++) yield return i;
            yield break;
        }

        yield return 1;
        if (CurrentPage > 3) yield return -1;

        for (int i = Math.Max(2, CurrentPage - 1); i <= Math.Min(TotalPages - 1, CurrentPage + 1); i++)
            yield return i;

        if (CurrentPage < TotalPages - 2) yield return -1;
        yield return TotalPages;
    }
}
